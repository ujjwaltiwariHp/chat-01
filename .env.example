# -----------------------------------------------------------------------------
# Root environment file for local development and Docker Compose.
# Copy this file to `.env` at the repository root and fill in real secrets.
# -----------------------------------------------------------------------------

# Runtime mode: development | production
NODE_ENV=development

# Global log verbosity
LOG_LEVEL=debug

# Service identity for logging and metrics
SERVICE_NAME=hp-intelligence-local

# -----------------------------------------------------------------------------
# Shared secrets (DO NOT USE THESE IN PRODUCTION)
# -----------------------------------------------------------------------------

# Internal token used for trusted service-to-service calls inside the monorepo.
INTERNAL_SERVICE_TOKEN=REPLACE_WITH_INTERNAL_SERVICE_TOKEN

# Secret accepted from the gateway when it calls downstream AI services.
GATEWAY_SERVICE_SECRET=REPLACE_WITH_GATEWAY_SERVICE_SECRET

# Secret accepted from the widget service when it calls downstream AI services.
WIDGET_SERVICE_SECRET=REPLACE_WITH_WIDGET_SERVICE_SECRET

# Cookie/session secret used by services for browser state.
SESSION_SECRET=REPLACE_WITH_A_SESSION_SECRET

# JWT signing secret for dashboard auth and any signed service tokens.
JWT_SECRET=REPLACE_WITH_A_JWT_SECRET

# Test Data Seeds (Match what is in migrations or seed scripts)
TEST_TENANT_ID=00000000-0000-0000-0000-000000000001
TEST_USER_ID=00000000-0000-0000-0000-000000000002
TEST_CUSTOMER_ID=00000000-0000-0000-0000-000000000005

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------

# PostgreSQL connection strings.
DATABASE_URL=postgres://postgres:postgres@localhost:5435/hp_intelligence
DB_URL=postgres://postgres:postgres@localhost:5435/hp_intelligence

# Individual PostgreSQL settings.
DB_HOST=localhost
DB_PORT=5435
DB_USER=postgres
DB_PASSWORD=REPLACE_WITH_A_DB_PASSWORD
DB_NAME=hp_intelligence

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------

# Redis password injected into the Redis container.
REDIS_PASSWORD=REPLACE_WITH_A_REDIS_PASSWORD

# Redis connection string; include password if set in REDIS_PASSWORD.
REDIS_URL=redis://:REPLACE_WITH_A_REDIS_PASSWORD@localhost:6379

# -----------------------------------------------------------------------------
# AI providers
# -----------------------------------------------------------------------------

# Global fallback OpenAI API key used if a service-specific key is not provided.
OPENAI_API_KEY=sk-your-openai-api-key

# Optional service-specific OpenAI keys. If unset, each service falls back to OPENAI_API_KEY.
CHATBOT_OPENAI_API_KEY=
HR_POLICY_OPENAI_API_KEY=
LEAD_SERVICE_OPENAI_API_KEY=

# Defaults
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=sk-ant-xxxx

# -----------------------------------------------------------------------------
# Auth and routing
# -----------------------------------------------------------------------------

AUTH_MODE=multi
# Tenant-to-gateway auth token. This is separate from the outbound webhook secret.
HP_BIZ_API_KEY=REPLACE_WITH_YOUR_HP_BIZ_API_TOKEN
DASHBOARD_URL=http://localhost:3000/dashboard

# -----------------------------------------------------------------------------
# Service ports
# -----------------------------------------------------------------------------

GATEWAY_PORT=4000
CHATBOT_PORT=4001
CATEGORIZER_PORT=4002
HR_POLICY_PORT=4003
SLACK_PORT=4006
WIDGET_PORT=4010
RAG_MIN_SCORE=0.35

# Internal network service URL
CHATBOT_SERVICE_URL=http://hp-chatbot-ai:4001
SLACKBOT_SERVICE_URL=http://localhost:4006

# -----------------------------------------------------------------------------
# SMTP (optional)
# -----------------------------------------------------------------------------

SMTP_HOST=localhost
SMTP_PORT=587
SMTP_USER=REPLACE_WITH_SMTP_USER
SMTP_PASS=REPLACE_WITH_SMTP_PASS
SMTP_FROM=HangingPanda Intelligence <noreply@hp-intelligence.local>

# -----------------------------------------------------------------------------
# Slackbot (optional)
# -----------------------------------------------------------------------------

SLACK_SIGNING_SECRET=REPLACE_WITH_SLACK_SIGNING_SECRET
SLACK_BOT_TOKEN=xoxb-REPLACE_WITH_SLACK_BOT_TOKEN

# -----------------------------------------------------------------------------
# Monitoring
# -----------------------------------------------------------------------------

GRAFANA_PORT=3001
PROMETHEUS_PORT=9090
GRAFANA_PASSWORD=REPLACE_WITH_GRAFANA_PASSWORD

# -----------------------------------------------------------------------------
# Slack Integration
# -----------------------------------------------------------------------------
SLACK_PORT=4005
SLACK_SIGNING_SECRET=REPLACE_WITH_SLACK_SIGNING_SECRET
SLACK_BOT_TOKEN=xoxb-REPLACE_WITH_BOT_TOKEN
SLACK_STREAM_DEBOUNCE_MS=600
