{
  "name": "@hp-intelligence/gateway",
  "version": "1.0.0",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "start": "node dist/server.js",
    "dev": "tsx watch --env-file=../../.env src/server.ts",
    "build": "tsc && tsc-alias",
    "migrate": "knex migrate:latest --knexfile knexfile.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --fix --max-warnings 0"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@hp-intelligence/core": "workspace:*",
    "drizzle-orm": "^0.45.1",
    "fastify": "^5.8.2",
    "fastify-plugin": "^5.0.1",
    "jsonwebtoken": "^9.0.3",
    "prom-client": "^15.1.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.5.0",
    "@types/pg": "^8.11.11",
    "dotenv": "^17.3.1",
    "knex": "^3.1.0",
    "pg": "^8.20.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "redis": "^4.7.0"
  }
}
