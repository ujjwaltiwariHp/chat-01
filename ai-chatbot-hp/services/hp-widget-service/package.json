{
  "name": "@hp-intelligence/widget-service",
  "version": "1.0.0",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "start": "node dist/server.js",
    "dev": "tsx watch --env-file=../../.env src/server.ts",
    "build": "tsc && tsc-alias",
    "migrate": "knex migrate:latest --knexfile knexfile.ts",
    "knex": "knex",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --fix --max-warnings 0"
  },
  "dependencies": {
    "@fastify/static": "^9.0.0",
    "@hp-intelligence/core": "workspace:*",
    "drizzle-orm": "^0.45.1",
    "fastify": "^5.8.2",
    "fastify-plugin": "^5.1.0",
    "ioredis": "^5.10.0",
    "knex": "^3.1.0",
    "nodemailer": "^8.0.3",
    "pg": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/pg": "^8.11.11",
    "drizzle-kit": "^0.30.6",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
