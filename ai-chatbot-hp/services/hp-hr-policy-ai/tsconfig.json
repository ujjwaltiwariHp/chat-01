{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "src",
    "baseUrl": ".",
    "paths": {
      "@hp-intelligence/core": ["../../packages/hp-ai-core/src"],
      "@hp-intelligence/core/*": ["../../packages/hp-ai-core/src/*"],
      "@/*": ["src/*"]
    }
  },
  "references": [
    { "path": "../../packages/hp-ai-core" }
  ],
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
