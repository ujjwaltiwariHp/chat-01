{
  "name": "@hp-intelligence/lead-categorizer-ai",
  "version": "1.0.0",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "start": "node dist/server.js",
    "dev": "tsx watch --env-file=../../.env src/server.ts",
    "build": "tsc && tsc-alias",
    "migrate": "knex migrate:latest --knexfile knexfile.ts",
    "migrate:rollback": "knex migrate:rollback --knexfile knexfile.ts",
    "seed": "tsx src/scripts/seed-data.ts",
    "export-schemas": "tsx src/utils/schema-exporter.ts",
    "test:rls": "tsx src/test/rls-matrix.ts",
    "generate-sdk": "openapi-typescript http://localhost:4002/documentation/json -o ../../packages/sdk/src/lead-categorizer.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --fix --max-warnings 0 --no-warn-ignored"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.5",
    "@hp-intelligence/core": "workspace:*",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/exporter-trace-otlp-http": "^0.214.0",
    "@opentelemetry/resources": "^2.6.1",
    "@opentelemetry/sdk-node": "^0.214.0",
    "@opentelemetry/sdk-trace-base": "^2.6.1",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "bullmq": "^5.74.1",
    "drizzle-orm": "^0.45.1",
    "fastify": "^5.8.2",
    "fastify-plugin": "^5.1.0",
    "knex": "^3.1.0",
    "luxon": "^3.7.2",
    "openai": "^4.104.0",
    "opossum": "^9.0.0",
    "pg": "^8.20.0",
    "pgvector": "^0.2.1",
    "prom-client": "^15.1.3",
    "zod": "^4.3.6",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@types/luxon": "^3.7.1",
    "@types/node": "^25.5.0",
    "@types/opossum": "^8.1.9",
    "@types/pg": "^8.11.11",
    "drizzle-kit": "^0.31.10",
    "openapi-typescript": "^7.13.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.7.1",
    "typescript": "^5.9.3"
  }
}
