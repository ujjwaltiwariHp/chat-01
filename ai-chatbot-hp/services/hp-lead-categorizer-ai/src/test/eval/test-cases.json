[
  {
    "id": "case-001",
    "name": "Chatbot: Mobile App Request",
    "source": "chatbot",
    "payload": {
      "transcript": [
        { "role": "assistant", "content": "Hi! Welcome to HangingPanda. How can I help you?" },
        { "role": "user", "content": "Hi, I need a mobile app for my restaurant business" },
        { "role": "assistant", "content": "Sure! Can you tell me more about what you're looking for?" },
        { "role": "user", "content": "I have 5 outlets in Pune, need an app for online ordering and table reservation" },
        { "role": "assistant", "content": "That sounds great. Do you have a budget range in mind?" },
        { "role": "user", "content": "Around 4-5 lakh, need it done in 3 months" },
        { "role": "assistant", "content": "Got it. Can I get your contact details?" },
        { "role": "user", "content": "Rahul Mehta, rahul@punefoods.com, 9876543210. WhatsApp pe contact karna" }
      ],
      "visitor": {
        "pageUrl": "https://hangingpanda.com/services/mobile-app",
        "referrer": "google.com",
        "location": "Pune, Maharashtra"
      }
    },
    "expected": {
      "classification": "HOT",
      "required_fields": ["email", "phone", "company_name"]
    }
  },
