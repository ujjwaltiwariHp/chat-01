{
  "name": "@hp-intelligence/core",
  "version": "1.0.0",
  "type": "module",
  "description": "Shared core library for HP-Intelligence services",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "development": "./src/index.ts",
        "default": "./dist/index.js"
      },
      "types": {
        "development": "./src/index.ts",
        "default": "./dist/index.d.ts"
      }
    },
    "./*": {
      "import": {
        "development": "./src/*.ts",
        "default": "./dist/*.js"
      },
      "types": {
        "development": "./src/*.ts",
        "default": "./dist/*.d.ts"
      }
    },
    "./*.js": {
      "import": {
        "development": "./src/*.ts",
        "default": "./dist/*.js"
      },
      "types": {
        "development": "./src/*.ts",
        "default": "./dist/*.d.ts"
      }
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc -w",
    "test": "echo \"Error: no test specified\" && exit 0",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --fix --max-warnings 0"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.32.1",
  "dependencies": {
    "@fastify/rate-limit": "^10.3.0",
    "@types/opossum": "^8.1.9",
    "drizzle-orm": "^0.45.1",
    "fastify": "^5.8.2",
    "fastify-plugin": "^5.1.0",
    "ioredis": "^5.10.0",
    "js-tiktoken": "^1.0.21",
    "jsonwebtoken": "^9.0.3",
    "nodemailer": "^8.0.3",
    "openai": "^4.104.0",
    "opossum": "^9.0.0",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "prom-client": "^15.1.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.5.0",
    "@types/nodemailer": "^7.0.11",
    "@types/pg": "^8.11.11",
    "typescript": "^5.9.3"
  }
}
